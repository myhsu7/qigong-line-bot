<%- include('../partials/header') %>

<div class="row">
    <div class="col-12">
        <div class="chart-container">
            <h5 class="mb-4">今日打卡狀態</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="kpi-card border border-success-subtle bg-success-subtle" role="button" id="checkedInCard">
                        <p>今日已打卡</p>
                        <h3 class="text-success" id="checkedInCount">-</h3>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="kpi-card border border-warning-subtle bg-warning-subtle" role="button" id="pendingCard">
                        <p>今日尚未打卡</p>
                        <h3 class="text-warning-emphasis" id="pendingCount">-</h3>
                    </div>
                </div>
            </div>

            <div id="checkedInPanel" class="mt-4 d-none">
                <h6 class="mb-3">今日已打卡學員</h6>
                <div id="checkedInList"></div>
                <div id="checkedInPager" class="d-flex align-items-center gap-2 mt-3"></div>
            </div>

            <div id="pendingPanel" class="mt-4 d-none">
                <h6 class="mb-3">今日尚未打卡學員</h6>
                <div id="pendingList"></div>
                <div id="pendingPager" class="d-flex align-items-center gap-2 mt-3"></div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="kpi-card">
            <p><%= i18n.total_checkins %></p>
            <h3><%= data.kpis.totalCheckins %></h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card">
            <p><%= i18n.active_users %></p>
            <h3><%= data.kpis.activeUsers %></h3>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card">
            <p><%= i18n.avg_daily_checkins %></p>
            <h3><%= data.kpis.avgDailyCheckins %></h3>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="chart-container">
            <h5 class="mb-3"><%= i18n.daily_trend %></h5>
            <% if (data.trend.length === 0) { %>
                <p class="text-center text-muted my-5"><%= i18n.no_data %></p>
            <% } else { %>
                <canvas id="trendChart" height="80"></canvas>
            <% } %>
        </div>
    </div>
</div>

<script>
    const trendData = <%- JSON.stringify(data.trend) %>;
    const lang = <%- JSON.stringify(lang) %>;
    const escapeHtml = (value) => String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const renderUserList = (containerId, users) => {
        const container = document.getElementById(containerId);
        if (!users || users.length === 0) {
            container.innerHTML = '<div class="text-muted">沒有資料</div>';
            return;
        }

        container.innerHTML = users.map((u) => `
            <div class="d-flex align-items-center justify-content-between border rounded px-3 py-2 mb-2 bg-white">
                <a class="text-decoration-none fw-bold" href="/line/admin-dashboard/method-analysis?period=30d&lang=${encodeURIComponent(lang)}&userId=${encodeURIComponent(u.lineUserId)}&name=${encodeURIComponent(u.displayName)}">${escapeHtml(u.displayName)}</a>
            </div>
        `).join('');
    };

    const renderPager = (containerId, page, totalPages, onPageChange) => {
        const container = document.getElementById(containerId);
        container.innerHTML = '';
        if (totalPages <= 1) return;

        const prev = document.createElement('button');
        prev.className = `btn btn-sm ${page <= 1 ? 'btn-outline-secondary' : 'btn-outline-primary'}`;
        prev.disabled = page <= 1;
        prev.textContent = '← 上一頁';
        prev.onclick = () => onPageChange(page - 1);

        const info = document.createElement('span');
        info.className = 'text-muted small';
        info.textContent = `第 ${page} / ${totalPages} 頁`;

        const next = document.createElement('button');
        next.className = `btn btn-sm ${page >= totalPages ? 'btn-outline-secondary' : 'btn-outline-primary'}`;
        next.disabled = page >= totalPages;
        next.textContent = '下一頁 →';
        next.onclick = () => onPageChange(page + 1);

        container.appendChild(prev);
        container.appendChild(info);
        container.appendChild(next);
    };

    const loadTodayList = async (type, page = 1) => {
        const res = await fetch(`/line/api/admin/${type}?page=${page}&limit=20`);
        const data = await res.json();
        const isChecked = type === 'today-checkins';
        document.getElementById(isChecked ? 'checkedInCount' : 'pendingCount').textContent = `${data.total}`;
        renderUserList(isChecked ? 'checkedInList' : 'pendingList', data.users || []);
        renderPager(isChecked ? 'checkedInPager' : 'pendingPager', data.page, data.totalPages, (nextPage) => loadTodayList(type, nextPage));
    };

    const showPanel = (panelIdToShow) => {
        ['checkedInPanel', 'pendingPanel'].forEach((id) => {
            document.getElementById(id).classList.toggle('d-none', id !== panelIdToShow);
        });
    };

    document.getElementById('checkedInCard').addEventListener('click', () => {
        showPanel('checkedInPanel');
        loadTodayList('today-checkins', 1);
    });

    document.getElementById('pendingCard').addEventListener('click', () => {
        showPanel('pendingPanel');
        loadTodayList('today-pending', 1);
    });
    
    if (trendData.length > 0) {
        const ctx = document.getElementById('trendChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: trendData.map(d => d.date),
                datasets: [{
                    label: '<%= i18n.total_checkins %>',
                    data: trendData.map(d => d.count),
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { precision: 0 }
                    }
                }
            }
        });
    }

    loadTodayList('today-checkins', 1);
    loadTodayList('today-pending', 1);
</script>

<%- include('../partials/footer') %>
