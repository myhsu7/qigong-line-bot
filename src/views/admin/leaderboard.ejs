<%- include('partials/header') %>

<div class="row">
    <div class="col-md-6">
        <div class="chart-container">
            <h5 class="mb-4"><%= i18n.top_total_days %></h5>
            <% if (data.totals.length === 0) { %>
                <p class="text-center text-muted my-5"><%= i18n.no_data %></p>
            <% } else { %>
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th><%= i18n.name %></th>
                            <th class="text-end"><%= i18n.days %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.totals.forEach(function(row, index) { %>
                        <tr>
                            <td class="text-muted"><%= index + 1 %></td>
                            <td class="fw-bold"><%= row.display_name %></td>
                            <td class="text-end text-primary fw-bold"><%= row.total_days %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="chart-container">
            <h5 class="mb-4"><%= i18n.top_streaks %></h5>
            <% if (data.streaks.length === 0) { %>
                <p class="text-center text-muted my-5"><%= i18n.no_data %></p>
            <% } else { %>
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th><%= i18n.name %></th>
                            <th class="text-end"><%= i18n.streak %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.streaks.forEach(function(row, index) { %>
                        <tr>
                            <td class="text-muted"><%= index + 1 %></td>
                            <td class="fw-bold"><%= row.displayName %></td>
                            <td class="text-end text-danger fw-bold"><%= row.maxStreak %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
