<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>我的成就</title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; background: linear-gradient(180deg,#f8fafc,#eef2ff); color: #1f2937; }
    .container { max-width: 760px; margin: 0 auto; padding: 20px; }
    .card { background: rgba(255,255,255,.92); backdrop-filter: blur(8px); border-radius: 18px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,.08); margin-bottom: 16px; }
    h1 { margin: 0 0 8px; font-size: 26px; }
    h2 { margin: 0 0 12px; font-size: 20px; }
    .muted { color: #6b7280; }
    .stat-grid { display:grid; grid-template-columns: repeat(2,1fr); gap: 12px; margin-top: 12px; }
    .stat { background:#f8fafc; border-radius:14px; padding:14px; }
    .stat .label { color:#6b7280; font-size:13px; }
    .stat .value { font-size:22px; font-weight:700; margin-top:6px; }
    .progress-wrap { background:#e5e7eb; border-radius:999px; overflow:hidden; height:12px; margin-top:10px; }
    .progress-bar { height:100%; background: linear-gradient(90deg,#06c755,#0ea5e9); width:0%; }
    .badge-grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(160px,1fr)); gap: 12px; }
    .badge-card { background:#fff; border:1px solid #eef2ff; border-radius:16px; padding:16px; min-height:130px; box-shadow: 0 4px 12px rgba(0,0,0,.04); }
    .badge-emoji { font-size:36px; }
    .badge-name { font-weight:700; margin-top:8px; font-size:15px; }
    .badge-desc { color:#6b7280; font-size:13px; margin-top:6px; line-height:1.4; }
    .badge-year { color:#9ca3af; font-size:12px; margin-top:4px; }
    .empty { text-align:center; color:#6b7280; padding:30px 0; }
    .loading { text-align:center; color:#6b7280; padding:24px 0; }
    @media (max-width: 640px) {
      .container { padding: 14px; }
      .stat-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>🏮 我的成就</h1>
      <div class="muted">查看你的境界、勳章與累積打卡成果。</div>
      <div id="summary" class="loading">載入中...</div>
    </div>

    <div class="card">
      <h2>🏆 榮譽勳章</h2>
      <div id="badgeGrid" class="badge-grid"></div>
      <div id="badgeEmpty" class="empty" style="display:none;">目前還沒有勳章，持續打卡很快就會有第一枚成就！</div>
    </div>
  </div>

  <script>
    const LIFF_ID = '<%= liffId %>';
    let lineUserId = '';
    let displayName = '';
    const escapeHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    const apiFetch = async (url) => {
      const separator = url.includes('?') ? '&' : '?';
      const finalUrl = `${url}${separator}displayName=${encodeURIComponent(displayName)}`;
      const res = await fetch(finalUrl, { headers: { 'x-line-user-id': lineUserId } });
      if (!res.ok) {
        const body = await res.json().catch(() => ({ error: 'Request failed' }));
        throw new Error(body.error || 'Request failed');
      }
      return res.json();
    };

    const init = async () => {
      await liff.init({ liffId: LIFF_ID });
      if (!liff.isLoggedIn()) {
        liff.login({ redirectUri: window.location.href });
        return;
      }
      const profile = await liff.getProfile();
      lineUserId = profile.userId;
      displayName = profile.displayName || '';
      try {
        const data = await apiFetch('/line/api/liff/achievements');
        const stats = data.stats || {};
        const nextMilestone = data.nextMilestone;

        let progressPercent = 100;
        if ((stats.totalCheckins || 0) < 30) progressPercent = ((stats.totalCheckins || 0) / 30) * 100;
        else if ((stats.totalCheckins || 0) < 90) progressPercent = (((stats.totalCheckins || 0) - 30) / 60) * 100;
        else if ((stats.totalCheckins || 0) < 200) progressPercent = (((stats.totalCheckins || 0) - 90) / 110) * 100;

        document.getElementById('summary').innerHTML = `
          <div style="font-size:18px;font-weight:700;margin-top:12px;">【當前境界】${escapeHtml(data.levelTitle)}</div>
          <div class="progress-wrap"><div class="progress-bar" style="width:${Math.max(0, Math.min(progressPercent, 100)).toFixed(1)}%"></div></div>
          <div class="muted" style="margin-top:8px;">${nextMilestone ? `距離 ${escapeHtml(nextMilestone.title)} 還差 ${nextMilestone.remaining} ${escapeHtml(nextMilestone.unit)}` : '你已達到目前最高等級，持續精進！'}</div>
          <div class="stat-grid">
            <div class="stat"><div class="label">目前連續打卡</div><div class="value">${stats.currentStreak || 0} 天</div></div>
            <div class="stat"><div class="label">最長連續打卡</div><div class="value">${stats.longestStreak || 0} 天</div></div>
            <div class="stat"><div class="label">總打卡天數</div><div class="value">${stats.totalCheckins || 0} 天</div></div>
            <div class="stat"><div class="label">最近打卡日期</div><div class="value" style="font-size:18px;">${escapeHtml(stats.lastCheckinDate || '-')}</div></div>
          </div>
        `;

        const badgeGrid = document.getElementById('badgeGrid');
        const badgeEmpty = document.getElementById('badgeEmpty');
        badgeGrid.innerHTML = '';

        const badges = data.badges || [];
        if (badges.length === 0) {
          badgeEmpty.style.display = 'block';
        } else {
          badgeEmpty.style.display = 'none';
          badges.forEach((badge) => {
            const yearText = badge.earned_year && badge.earned_year !== 0 ? `<div class="badge-year">(${badge.earned_year})</div>` : '';
            const card = document.createElement('div');
            card.className = 'badge-card';
            card.innerHTML = `
              <div class="badge-emoji">${escapeHtml(badge.emoji || '🏅')}</div>
              <div class="badge-name">${escapeHtml(badge.name)}</div>
              <div class="badge-desc">${escapeHtml(badge.description || '')}</div>
              ${yearText}
            `;
            badgeGrid.appendChild(card);
          });
        }
      } catch (error) {
        document.getElementById('summary').innerHTML = `<div class="empty">載入失敗：${escapeHtml(error.message)}</div>`;
      }
    };

    init();
  </script>
</body>
</html>
