<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>我的成就</title>
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; background: #f6f7fb; color: #1f2937; }
    .container { max-width: 760px; margin: 0 auto; padding: 20px; }
    .card { background:#fff; border-radius:14px; padding:20px; box-shadow:0 8px 24px rgba(0,0,0,.08); margin-bottom:16px; }
    h1 { font-size:24px; margin:0 0 8px; }
    .muted { color:#6b7280; }
    .stat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-top:14px; }
    .stat { background:#f9fafb; border-radius:12px; padding:14px; text-align:center; }
    .stat .value { font-size:24px; font-weight:800; color:#06c755; }
    .badge-list { display:flex; flex-wrap:wrap; gap:10px; }
    .badge-item { background:#fff7ed; color:#9a3412; border-radius:999px; padding:8px 12px; font-size:13px; font-weight:600; }
    .empty,.loading { text-align:center; color:#6b7280; padding:24px 0; }
    .progress { height:12px; background:#e5e7eb; border-radius:999px; overflow:hidden; margin-top:12px; }
    .progress-bar { height:100%; background:linear-gradient(90deg,#06c755,#0ea5e9); width:0%; }
    @media (max-width: 640px) { .stat-grid { grid-template-columns:1fr; } }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>我的成就</h1>
      <div class="muted">查看你的境界、勳章與累積打卡成果。</div>
      <div id="summary" class="loading">載入中...</div>
    </div>
    <div class="card">
      <h2 style="margin-top:0;">榮譽勳章</h2>
      <div id="badgeList" class="loading">載入中...</div>
    </div>
  </div>
  <script>
    const LIFF_ID = '<%= liffId %>';
    let lineUserId = '';
    let displayName = '';
    const escapeHtml = (value) => String(value || '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');

    const apiFetch = async (url) => {
      const res = await fetch(url, { headers: { 'x-line-user-id': lineUserId } });
      if (!res.ok) {
        const body = await res.json().catch(() => ({ error: 'Request failed' }));
        throw new Error(body.error || 'Request failed');
      }
      return res.json();
    };

    const init = async () => {
      await liff.init({ liffId: LIFF_ID });
      if (!liff.isLoggedIn()) {
        liff.login({ redirectUri: window.location.href });
        return;
      }
      const profile = await liff.getProfile();
      lineUserId = profile.userId;
      displayName = profile.displayName || '';
      try {
        const data = await apiFetch('/line/api/liff/achievements');
        const stats = data.stats || {};
        let progressPercent = 100;
        if ((stats.totalCheckins || 0) < 30) progressPercent = ((stats.totalCheckins || 0) / 30) * 100;
        else if ((stats.totalCheckins || 0) < 90) progressPercent = (((stats.totalCheckins || 0) - 30) / 60) * 100;
        else if ((stats.totalCheckins || 0) < 200) progressPercent = (((stats.totalCheckins || 0) - 90) / 110) * 100;
        document.getElementById('summary').innerHTML = `
          <div style="font-size:18px;font-weight:700;">【當前境界】${escapeHtml(data.levelTitle)}</div>
          <div class="progress"><div class="progress-bar" style="width:${Math.max(0, Math.min(progressPercent, 100)).toFixed(1)}%"></div></div>
          <div class="muted" style="margin-top:8px;">${data.nextMilestone ? `距離 ${escapeHtml(data.nextMilestone.title)} 還差 ${data.nextMilestone.remaining} ${escapeHtml(data.nextMilestone.unit)}` : '你已達到目前最高等級，持續精進！'}</div>
          <div class="stat-grid">
            <div class="stat"><div class="value">${stats.currentStreak || 0}</div><div class="muted">目前連續打卡</div></div>
            <div class="stat"><div class="value">${stats.longestStreak || 0}</div><div class="muted">最高連打</div></div>
            <div class="stat"><div class="value">${stats.totalCheckins || 0}</div><div class="muted">總打卡</div></div>
          </div>
        `;
        const badges = data.badges || [];
        if (badges.length === 0) {
          document.getElementById('badgeList').innerHTML = '<div class="empty">目前還沒有勳章，快去打卡解鎖吧！</div>';
        } else {
          document.getElementById('badgeList').innerHTML = `<div class="badge-list">${badges.map((badge) => {
            const yearText = badge.earned_year && badge.earned_year !== 0 ? ` (${badge.earned_year})` : '';
            return `<span class="badge-item">${escapeHtml(badge.emoji || '🏅')} ${escapeHtml(badge.name)}${yearText}</span>`;
          }).join('')}</div>`;
        }
      } catch (error) {
        document.getElementById('summary').innerHTML = `<div class="empty">載入失敗：${error.message}</div>`;
        document.getElementById('badgeList').innerHTML = `<div class="empty">載入失敗：${error.message}</div>`;
      }
    };
    init();
  </script>
</body>
</html>
